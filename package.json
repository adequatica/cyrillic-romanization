{
  "name": "cyrillic-romanization",
  "version": "1.2.1",
  "description": "Convert Cyrillic characters to Latin characters (transliteration)",
  "keywords": [
    "ala-lc",
    "alphabet",
    "azerbaijani",
    "belarusian",
    "bulgarian",
    "cyrillic",
    "gaj",
    "iso9",
    "kazakh",
    "language",
    "latin",
    "macedonian",
    "mongolian",
    "montenegrin",
    "romanization",
    "russian",
    "serbian",
    "transliteration",
    "turkmen",
    "ukrainian",
    "uzbek"
  ],
  "repository": {
    "type": "git",
    "url": "https://github.com/adequatica/cyrillic-romanization"
  },
  "author": "Andrey Enin",
  "license": "MIT",
  "type": "module",
  "engines": {
    "node": ">=20"
  },
  "main": "dist/index.js",
  "devDependencies": {
    "@eslint/js": "9.39.4",
    "eslint": "10.4.0",
    "globals": "17.6.0",
    "prettier": "3.8.3",
    "typescript": "5.9.3",
    "typescript-eslint": "8.59.3",
    "vitest": "4.1.6"
  },
  "scripts": {
    "build": "tsc --project tsconfig.build.json",
    "format": "npx prettier --write .",
    "lint": "eslint '**/*.{js,ts}'",
    "lint:fix": "eslint --fix",
    "test": "vitest run"
  },
  "files": [
    "dist",
    "README.md",
    "package.json"
  ]
}
